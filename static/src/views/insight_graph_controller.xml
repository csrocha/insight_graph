<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="insight_graph.InsightGraphController">
        <Layout display="props.display" className="'o_insight_graph_view'">
            <t t-set-slot="layout-actions">
                <SearchBar t-if="searchBarToggler.state.showSearchBar"/>
            </t>
            <t t-set-slot="control-panel-navigation-additional">
                <t t-component="searchBarToggler.component" t-props="searchBarToggler.props"/>
            </t>
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center h-100">
                    <i class="fa fa-spinner fa-spin fa-3x text-muted"/>
                </div>
            </t>
            <t t-elif="state.error">
                <div class="alert alert-danger m-4" t-esc="state.error"/>
            </t>
            <t t-else="">
                <InsightGraphRenderer
                    graphData="state.graphData"
                    primaryModel="props.resModel"
                    modelConfigs="state.modelConfigs"
                    onOpenForm.bind="onOpenForm"
                    onDeleteNode.bind="onDeleteNode"
                    onLinkNodes.bind="onLinkNodes"
                    onCreateAndLink.bind="onCreateAndLink"
                    onExecuteAction.bind="onExecuteAction"
                    onPinNode.bind="onPinNode"
                    onUnpinNode.bind="onUnpinNode"
                />
            </t>
        </Layout>
    </t>
</templates>
